{
    "compilerOptions": {
        "module": "Node16",
        "target": "es2022",
        "outDir": "./dist",
        "rootDir": "./",
        "sourceMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "moduleResolution": "Node16"
    },
    "include": ["src/**/*", "scripts/**/*"]
}
